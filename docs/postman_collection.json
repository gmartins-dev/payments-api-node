{
  "info": {
    "_postman_id": "d5bc2d2a-0a90-4fc0-83ff-13c4c5be7a0f",
    "name": "Payments API Node",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection para validar health check, Swagger e o fluxo de pagamentos idempotentes desta API."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "idempotencyKey",
      "value": "payment-001"
    },
    {
      "key": "amount",
      "value": "100"
    },
    {
      "key": "customerId",
      "value": "customer-1"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Valida se a API está operacional."
      },
      "response": []
    },
    {
      "name": "Swagger UI",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/docs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "docs"
          ]
        },
        "description": "Abre a documentação Swagger da API."
      },
      "response": []
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": {{amount}},\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments"
              ]
            },
            "description": "Cria um pagamento novo para a chave de idempotência informada."
          },
          "response": []
        },
        {
          "name": "Replay Same Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": {{amount}},\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments"
              ]
            },
            "description": "Repete exatamente a mesma chamada para observar o replay persistido."
          },
          "response": []
        },
        {
          "name": "Create With Different Payload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 150,\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments"
              ]
            },
            "description": "Usa a mesma chave com payload diferente para provocar conflito 409."
          },
          "response": []
        }
      ]
    }
  ]
}
